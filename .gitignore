# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock
.DS_Store

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# TypeScript
typings/
*.tsbuildinfo
dist/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# Environment variables
.env
.env.test
.env.local
# database.env est commité volontairement : il contient juste le chemin
# local vers dev.db, pas de secret. Le prof en a besoin pour lancer le projet.

# Caches
.cache
.next
.nuxt
.vuepress/dist
.serverless/
.fusebox/
.dynamodb/
.webpack/

# Vite (build output)
.vite/

# Electron Forge (production builds)
out/

# Angular build output
renderer/app/dist/

# SQLite database (générée localement, jamais commitée)
*.db
*.db-journal

# Prisma : on commit le schema et les migrations,
# mais PAS la base ni le client généré
src/prisma/generated/

# IDE / OS
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
.idea/

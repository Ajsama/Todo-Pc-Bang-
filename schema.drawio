                <mxCell id="legende" value="🔑 Clé primaire (PK)&#xa;🔗 Clé étrangère (FK)&#xa;&#xa;Cardinalités Merise : min,max de chaque côté&#xa;( 0,N  /  1,1  /  0,1 )&#xa;&#xa;La flèche part de la table « 1 » vers la table « plusieurs »&#xa;(celle qui contient la clé étrangère).&#xa;&#xa;Une table de jonction (N:M) a une clé primaire&#xa;composée de ses deux clés étrangères : PK (a, b)." style="text;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;whiteSpace=wrap;" parent="1" vertex="1">
                    <mxGeometry x="40" y="660" width="380" height="200" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>

// =========================================================================
//  PC Bang Manager — schema.prisma
//  9 modèles : 4 existants + 3 nouveaux + 2 tables de jonction N:M
// =========================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// -------------------------------------------------------------------------
//  1. Abonnement
// -------------------------------------------------------------------------
model Abonnement {
  id_abonnement Int      @id @default(autoincrement())
  type          String
  prix          Float?
  duree         Int?
  clients       Client[]
}

// -------------------------------------------------------------------------
//  2. Client
// -------------------------------------------------------------------------
model Client {
  id_client     Int           @id @default(autoincrement())
  nom           String?
  prenom        String?
  email         String?
  telephone     String?
  id_abonnement Int?
  abonnement    Abonnement?   @relation(fields: [id_abonnement], references: [id_abonnement], onDelete: SetNull)
  reservations  Reservation[]
}

// -------------------------------------------------------------------------
//  3. Poste
// -------------------------------------------------------------------------
model Poste {
  id_poste     Int           @id @default(autoincrement())
  numero_poste String?
  statut       String        @default("Libre")
  type         String?
  reservations Reservation[]
  jeux         PosteJeu[]
}

// -------------------------------------------------------------------------
//  4. Reservation
// -------------------------------------------------------------------------
model Reservation {
  id_reservation Int                 @id @default(autoincrement())
  id_client      Int?
  id_poste       Int?
  date_debut     DateTime?
  duree          Int?
  statut         String              @default("EnAttente")
  client         Client?             @relation(fields: [id_client], references: [id_client], onDelete: SetNull)
  poste          Poste?              @relation(fields: [id_poste], references: [id_poste], onDelete: SetNull)
  consommations  ReservationSnack[]
}

// -------------------------------------------------------------------------
//  5. Categorie
// -------------------------------------------------------------------------
model Categorie {
  id_categorie Int     @id @default(autoincrement())
  nom          String
  snacks       Snack[]
}

// -------------------------------------------------------------------------
//  6. Snack
// -------------------------------------------------------------------------
model Snack {
  id_snack     Int                 @id @default(autoincrement())
  nom          String
  prix         Float
  stock        Int                 @default(0)
  id_categorie Int?
  categorie    Categorie?          @relation(fields: [id_categorie], references: [id_categorie], onDelete: SetNull)
  reservations ReservationSnack[]
}

// -------------------------------------------------------------------------
//  7. Jeu
// -------------------------------------------------------------------------
model Jeu {
  id_jeu  Int        @id @default(autoincrement())
  titre   String
  editeur String?
  genre   String?
  annee   Int?
  postes  PosteJeu[]
}

// -------------------------------------------------------------------------
//  8. ReservationSnack — table de jonction N:M riche
//     Porte quantite + prix_unitaire (figé au moment de la commande)
//     onDelete différenciés : Cascade côté Reservation, Restrict côté Snack
// -------------------------------------------------------------------------
model ReservationSnack {
  id_reservation Int
  id_snack       Int
  quantite       Int         @default(1)
  prix_unitaire  Float
  reservation    Reservation @relation(fields: [id_reservation], references: [id_reservation], onDelete: Cascade)
  snack          Snack       @relation(fields: [id_snack], references: [id_snack], onDelete: Restrict)

  @@id([id_reservation, id_snack])
}

// -------------------------------------------------------------------------
//  9. PosteJeu — table de jonction N:M pure
//     Association poste ↔ jeu installé
// -------------------------------------------------------------------------
model PosteJeu {
  id_poste Int
  id_jeu   Int
  poste    Poste @relation(fields: [id_poste], references: [id_poste], onDelete: Cascade)
  jeu      Jeu   @relation(fields: [id_jeu], references: [id_jeu], onDelete: Cascade)

  @@id([id_poste, id_jeu])
}
